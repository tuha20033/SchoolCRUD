@using Application.Interface
@using Domain.Entities
@using MudBlazor
@inject ISchoolRepository SchoolRepository

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.School" Class="mr-2" />
            @(Id <= 0 ? "Thêm Trường Học" : "Chỉnh Sửa Trường Học")
        </MudText>
    </TitleContent>

    <DialogContent>
        <MudForm @ref="form" @bind-IsValid="isValid">
            <MudTextField @bind-Value="school.Name"
                          Label="Name"
                          Required="true"
                          RequiredError="Vui lòng nhập tên"
                          Class="mb-3" />

            <MudTextField @bind-Value="school.Address"
                          Label="Address"
                          Required="true"
                          RequiredError="Vui lòng nhập địa chỉ"
                          Class="mb-3" />

            <MudTextField @bind-Value="school.City"
                          Label="City"
                          Class="mb-3" />

            <MudTextField @bind-Value="school.State"
                          Label="State"
                          Class="mb-3" />

            <MudTextField @bind-Value="school.ZipCode"
                          Label="ZipCode"
                          Class="mb-3" />

            <MudTextField @bind-Value="school.Country"
                          Label="Country"
                          Class="mb-3" />
        </MudForm>
    </DialogContent>

    <DialogActions>
        <MudButton OnClick="Cancel">Hủy</MudButton>
        <MudButton Color="Color.Primary"
                   Variant="Variant.Filled"
                   OnClick="HandleSubmit"
                  >
            Lưu
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; }
    [Parameter] public int Id { get; set; }

    private School school = new School();
    private MudForm form;
    private bool isValid;

    protected override async Task OnInitializedAsync()
    {
        if (Id > 0)
            school = await SchoolRepository.GetByIdAsync(Id) ?? new School();
    }

    private async Task HandleSubmit()
    {
        await form.Validate();
        if (!isValid) return;

        if (Id <= 0)
            await SchoolRepository.AddAsync(school);
        else
            await SchoolRepository.UpdateAsync(school);

        MudDialog.Close(DialogResult.Ok(true));
    }

    private void Cancel() => MudDialog.Cancel();
}